# hostname = business-cdn.shouji.sogou.com, ios.sogou.com, android.sogou.com, h5api.sginput.qq.com
# 开屏广告
^https?://(ios|android)\.sogou\.com/[^/]+/sogou_input_[^/]+/[^/]+/index\.html - reject


# >>>>>>>>>>>>>>> 🔧 <<<<<<<<<<<<<<
# > 腾讯游戏
